PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/leetclone
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Judge0 execution engine. Defaults to https://ce.judge0.com if omitted.
JUDGE0_API_URL=https://ce.judge0.com

# Optional, depending on the Judge0 provider you use.
# JUDGE0_API_KEY=
# JUDGE0_API_KEY_HEADER=X-Auth-Token
# JUDGE0_RAPIDAPI_HOST=judge0-ce.p.rapidapi.com

JUDGE0_CPU_TIME_LIMIT_SECONDS=2
JUDGE0_CPU_EXTRA_TIME_SECONDS=0.5
JUDGE0_WALL_TIME_LIMIT_SECONDS=5
JUDGE0_MEMORY_LIMIT_KB=128000
JUDGE0_STACK_LIMIT_KB=64000
JUDGE0_MAX_PROCESSES=60
JUDGE0_ENABLE_PER_PROCESS_TIME_LIMIT=false
JUDGE0_ENABLE_PER_PROCESS_MEMORY_LIMIT=false
JUDGE0_MAX_FILE_SIZE_KB=1024
JUDGE0_POLL_TIMEOUT_MS=30000
